FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive

# ---------------------------
# 1. Locale
# ---------------------------
RUN apt-get update && apt-get install -y locales \
    && locale-gen en_US en_US.UTF-8 \
    && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
ENV LANG=en_US.UTF-8

# ---------------------------
# 2. Core + OpenGL + GLFW + X11
# ---------------------------
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    pkg-config \
    libusb-1.0-0-dev \
    libudev-dev \
    libglfw3-dev \
    libglfw3 \
    libgl1-mesa-dev \
    libglu1-mesa-dev \
    libx11-dev \
    libxrandr-dev \
    libxi-dev \
    libxcursor-dev \
    libxinerama-dev \
    libxxf86vm-dev \
    libopencv-dev \
    mesa-utils \
    udev \
    && rm -rf /var/lib/apt/lists/*
    
# install python
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
    numpy \
    opencv-python \
    openni

# 🔥 สำคัญ: ให้ CMake หา glfw เจอจริง
RUN pkg-config --modversion glfw3

# ---------------------------
# 3. Workspace
# ---------------------------
WORKDIR /intern_MuroranIT
COPY . .

# ---------------------------
# 4. Build Orbbec SDK + Viewer
# ---------------------------
RUN cd OrbbecSDK/OrbbecSDK && \
    rm -rf build && mkdir build && cd build && \
    cmake .. -DBUILD_EXAMPLES=ON && \
    make -j$(nproc)



# ---------------------------
# 5. Environment
# ---------------------------
ENV LD_LIBRARY_PATH=/intern_MuroranIT/OrbbecSDK/OrbbecSDK/build/lib

# ---------------------------
# 6. Default
# ---------------------------
CMD ["bash"]